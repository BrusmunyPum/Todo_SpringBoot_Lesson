        {
          "name": "DELETE — Delete Comment",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {"raw": "{{base_url}}/api/v1/tasks/{{task_id}}/comments/{{comment_id}}", "host": ["{{base_url}}"], "path": ["api","v1","tasks","{{task_id}}","comments","{{comment_id}}"]}
          },
          "event": [{"listen": "test","script": {"exec": [
